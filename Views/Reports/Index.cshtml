@model IEnumerable<Rota.Models.Shift>
@{
    ViewData["Title"] = "Reports";
}

<div class="container">
    <h2 class="mb-4 text-gradient">
        <i class="bi bi-graph-up-arrow me-2"></i>
        Reports Dashboard
    </h2>

    <!-- Smart Summary Panel -->
    <div class="row row-cols-1 row-cols-md-4 g-3 mb-4">
        <div class="col">
            <div class="card border-0 shadow-sm h-100 animate__animated animate__fadeIn">
                <div class="card-body text-center">
                    <i class="bi bi-bar-chart-fill display-6 text-primary mb-2"></i>
                    <h6 class="text-muted">Total Shifts</h6>
                    <h3 class="text-primary">@ViewBag.TotalShifts</h3>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card border-0 shadow-sm h-100 animate__animated animate__fadeIn animate__delay-1s">
                <div class="card-body text-center">
                    <i class="bi bi-person-badge-fill display-6 text-info mb-2"></i>
                    <h6 class="text-muted">Avg. Shifts per Employee</h6>
                    <h3 class="text-info">@ViewBag.AvgShiftsPerUser</h3>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card border-0 shadow-sm h-100 animate__animated animate__fadeIn animate__delay-2s">
                <div class="card-body text-center">
                    <i class="bi bi-umbrella-fill display-6 text-success mb-2"></i>
                    <h6 class="text-muted">Total Holidays Used</h6>
                    <h3 class="text-success">@ViewBag.TotalHolidays</h3>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card border-0 shadow-sm h-100 animate__animated animate__fadeIn animate__delay-3s">
                <div class="card-body text-center">
                    <i class="bi bi-exclamation-triangle-fill display-6 text-danger mb-2"></i>
                    <h6 class="text-muted">Users < 5 Days Holiday</h6>
                    <h3 class="text-danger">@ViewBag.LowBalanceUsers.Count</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Top Performers + Alerts -->
    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100 animate__animated animate__fadeInUp">
                <div class="card-body">
                    <h5 class="card-title text-primary"><i class="bi bi-trophy-fill me-2"></i>Top 3 Most Active Employees</h5>
                    <ul class="list-group list-group-flush">
                        @foreach (var user in ViewBag.TopUsers)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span>@user.User</span>
                                <span class="badge bg-primary rounded-pill">@user.ShiftCount shifts</span>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100 animate__animated animate__fadeInUp animate__delay-1s">
                <div class="card-body">
                    <h5 class="card-title text-danger"><i class="bi bi-bell-fill me-2"></i>Low Holiday Balance</h5>
                    @if (ViewBag.LowBalanceUsers.Count == 0)
                    {
                        <p class="text-muted">No users under 5 days 🎉</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var user in ViewBag.LowBalanceUsers)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <span>@user.User</span>
                                    <span class="badge bg-danger">@user.Remaining days left</span>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Chart Section -->
    <div class="row g-4">
        <div class="col-md-6">
            <div class="card shadow-lg w-100 h-100 border-0">
                <div class="card-body">
                    <h5 class="card-title text-primary">Shift Summary</h5>
                    <canvas id="shiftChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-lg w-100 h-100 border-0">
                <div class="card-body">
                    <h5 class="card-title text-info">Shifts by Weekday</h5>
                    <canvas id="weekdayChart" height="120"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-lg w-100 h-100 border-0">
                <div class="card-body">
                    <h5 class="card-title text-success">Holiday Usage</h5>
                    <canvas id="holidayChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-lg w-100 h-100 border-0">
                <div class="card-body">
                    <h5 class="card-title text-secondary">Detailed Holiday Usage</h5>
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>User</th>
                                    <th>Used</th>
                                    <th>Remaining</th>
                                    <th>Last Holiday</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < ViewBag.HolidayUsageLabels.Count; i++)
                                {
                                    <tr>
                                        <td>@ViewBag.HolidayUsageLabels[i]</td>
                                        <td>@ViewBag.HolidayUsedData[i]</td>
                                        <td>@ViewBag.HolidayRemainingData[i]</td>
                                        <td>@ViewBag.LastHolidayDate[i]</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card shadow-lg border-0">
                <div class="card-body">
                    <h5 class="card-title text-secondary">Under 18 Workers – Hours Worked</h5>
                    @if (ViewBag.Under18Names != null && ((List<string>)ViewBag.Under18Names).Count > 0)
                    {
                        var names = (List<string>)ViewBag.Under18Names;
                        var hours = (List<double>)ViewBag.Under18Hours;

                        <div class="table-responsive">
                            <table class="table table-bordered table-striped align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Name</th>
                                        <th>Total Hours</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < names.Count; i++)
                                    {
                                        <tr>
                                            <td>@names[i]</td>
                                            <td>@hours[i]</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>No under 18 workers found.
                        </div>
                    }
                </div>
            </div>
        </div>



@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        new Chart(document.getElementById('shiftChart').getContext('2d'), {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(ViewBag.ShiftLabels)),
                datasets: [{
                    label: 'Shifts per Employee',
                    data: @Html.Raw(Json.Serialize(ViewBag.ShiftData)),
                    backgroundColor: 'rgba(54, 162, 235, 0.7)'
                }]
            }
        });

        new Chart(document.getElementById('holidayChart').getContext('2d'), {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(ViewBag.HolidayUsageLabels)),
                datasets: [
                    {
                        label: 'Used',
                        data: @Html.Raw(Json.Serialize(ViewBag.HolidayUsedData)),
                        backgroundColor: 'rgba(255, 99, 132, 0.7)'
                    },
                    {
                        label: 'Remaining',
                        data: @Html.Raw(Json.Serialize(ViewBag.HolidayRemainingData)),
                        backgroundColor: 'rgba(75, 192, 192, 0.7)'
                    }
                ]
            },
            options: {
                responsive: true,
                scales: { y: { beginAtZero: true, max: 28 } }
            }
        });

        new Chart(document.getElementById('weekdayChart').getContext('2d'), {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(ViewBag.WeekdayLabels)),
                datasets: [{
                    label: 'Shifts by Weekday',
                    data: @Html.Raw(Json.Serialize(ViewBag.WeekdayCounts)),
                    backgroundColor: 'rgba(153, 102, 255, 0.7)'
                }]
            },
            options: {
                responsive: true,
                scales: { y: { beginAtZero: true } }
            }
        });
    </script>
}
