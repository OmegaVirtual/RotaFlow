@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@inject Rota.Data.ApplicationDbContext DbContext

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TimeNest</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Rota.styles.css" asp-append-version="true" />
    <style>
        .navbar-premium {
            background: linear-gradient(90deg, #1f1c2c, #928dab);
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
            padding-top: 1rem;
            padding-bottom: 1rem;
        }

        .navbar-premium .nav-link,
        .navbar-premium .navbar-brand {
            color: white !important;
            font-size: 1.1rem;
        }

        .navbar-premium .nav-link:hover {
            color: #ffc107 !important;
        }

        .navbar-brand img {
            height: 50px;
            width: auto;
            margin-right: 15px;
        }

        .footer {
            background-color: #f8f9fa;
            font-size: 0.9rem;
        }

        .badge {
            font-size: 0.8rem;
        }

        .navbar-collapse {
            flex-direction: row !important;
            justify-content: space-between !important;
            align-items: center !important;
        }

        .navbar-nav {
            flex-direction: row !important;
            gap: 1rem;
        }

        .navbar-nav .nav-item {
            display: flex;
            align-items: center;
        }

        .navbar-toggler {
            border-color: rgba(255, 255, 255, 0.1);
        }

        .notification-bell {
            animation: ring 0.8s ease-in-out infinite;
        }

        @@keyframes ring {
            0% { transform: rotate(0); }
            25% { transform: rotate(15deg); }
            50% { transform: rotate(-15deg); }
            75% { transform: rotate(10deg); }
            100% { transform: rotate(0); }
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-premium">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/TimeNestLogo.png" alt="TimeNest Logo" />
                    <span class="fs-3">TimeNest</span>
                </a>

                <button class="navbar-toggler text-white" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon bg-light rounded"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door-fill me-1"></i>Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Shift" asp-action="Index">
                                <i class="bi bi-calendar-event-fill me-1"></i>Shifts
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Employees" asp-action="Index">
                                <i class="bi bi-people-fill me-1"></i>Employees
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="ShiftRequest" asp-action="Index">
                                <i class="bi bi-journal-text me-1"></i>Requests
                            </a>
                        </li>
                        @if (User.IsInRole("Manager"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Reports" asp-action="Index">
                                    <i class="bi bi-graph-up-arrow me-1"></i>Reports
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item">
                                <a class="nav-link position-relative" asp-controller="Notifications" asp-action="Index" title="View Notifications">
                                    <i class="bi bi-bell-fill me-1 @(ViewBag.UnreadCount != null && (int)ViewBag.UnreadCount > 0 ? "notification-bell" : "")"></i> Notifications
                                    @if (ViewBag.UnreadCount != null && (int)ViewBag.UnreadCount > 0)
                                    {
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                            @ViewBag.UnreadCount
                                            <span class="visually-hidden">unread notifications</span>
                                        </span>
                                    }
                                </a>
                            </li>

                            <li class="nav-item d-flex align-items-center">
                                @{
                                    var currentUser = await UserManager.GetUserAsync(User);
                                    var profile = currentUser != null ? DbContext.UserProfiles.FirstOrDefault(p => p.UserId == currentUser.Id) : null;
                                    var displayName = profile?.FullName ?? currentUser?.UserName;
                                    var profileImage = !string.IsNullOrEmpty(profile?.ProfileImagePath) ? profile.ProfileImagePath : "/images/default-user.png";
                                }
                                <a class="nav-link text-white d-flex align-items-center gap-2" asp-area="Identity" asp-page="/Account/Manage/Index">
                                    <img src="@profileImage" alt="Profile" class="rounded-circle" style="height: 40px; width: 40px; object-fit: cover;" />
                                    @displayName
                                    @if (User.IsInRole("Manager"))
                                    {
                                        <span class="badge bg-success ms-2">Manager</span>
                                    }
                                    else if (User.IsInRole("Worker"))
                                    {
                                        <span class="badge bg-warning text-dark ms-2">Worker</span>
                                    }
                                </a>
                            </li>

                            <li class="nav-item">
                                <form class="form-inline ms-3" asp-area="Identity" asp-page="/Account/Logout" method="post">
                                    <button type="submit" class="btn btn-outline-light">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Identity" asp-page="/Account/Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="footer mt-auto py-4 text-center text-white" style="background: linear-gradient(90deg, #1f1c2c, #928dab);">
        <div class="container">
            <span class="fw-bold fs-5">© 2025 - TimeNest</span> |
            <a asp-controller="Home" asp-action="Privacy" class="text-white fw-semibold fs-5 text-decoration-underline">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <div aria-live="polite" aria-atomic="true" class="position-fixed bottom-0 end-0 p-3" style="z-index: 1080">
        <div class="toast align-items-center text-white bg-primary border-0 shadow" role="alert" id="toastMessage" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    @TempData["Message"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

    @if (TempData["Message"] != null)
    {
        <script>
            window.addEventListener('DOMContentLoaded', () => {
                const toast = new bootstrap.Toast(document.getElementById('toastMessage'));
                toast.show();
            });
        </script>
    }
</body>
</html>