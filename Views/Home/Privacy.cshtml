@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10 animate__animated animate__fadeIn">
            <div class="card shadow-lg border-0">
                <div class="card-body p-5">
                    <h2 class="text-primary mb-4">
                        <i class="bi bi-shield-lock-fill me-2"></i>Privacy & Data Protection
                    </h2>

                    <p class="lead mb-4 text-muted">
                        At <strong>TimeNest</strong>, we value your trust. This privacy policy outlines how we handle your data with care and responsibility.
                    </p>

                    <div class="mb-4">
                        <h5><i class="bi bi-person-fill-lock me-2 text-secondary"></i> What We Collect</h5>
                        <ul class="list-unstyled">
                            <li><i class="bi bi-check-circle-fill text-success me-2"></i> Employee names and contact details</li>
                            <li><i class="bi bi-check-circle-fill text-success me-2"></i> Shift assignments and availability</li>
                            <li><i class="bi bi-check-circle-fill text-success me-2"></i> Holiday requests and approvals</li>
                        </ul>
                    </div>

                    <div class="mb-4">
                        <h5><i class="bi bi-shield-check me-2 text-secondary"></i> How We Use Your Data</h5>
                        <p>Your data is used solely to manage staff scheduling, track attendance, and streamline communication within your team. We never sell or share your information with third parties.</p>
                    </div>

                    <div class="mb-4">
                        <h5><i class="bi bi-lock-fill me-2 text-secondary"></i> Data Security</h5>
                        <p>We use industry-standard encryption and access controls to keep your information safe. Only authorized managers can access sensitive data.</p>
                    </div>

                    <div class="mb-4">
                        <h5><i class="bi bi-person-fill-gear me-2 text-secondary"></i> Your Rights</h5>
                        <p>You have full control over your data. You may request to view, update, or delete your information at any time by contacting your account administrator.</p>
                    </div>

                    <div>
                        <p class="text-muted small">
                            <i class="bi bi-calendar3 me-2"></i>Policy last updated: @DateTime.UtcNow.ToString("MMMM dd, yyyy")
                        </p>
                    </div>

                    <hr />

                    <div class="text-center">
                        <i class="bi bi-heart-fill text-danger fs-4"></i>
                        <p class="mt-2 text-muted">Thank you for trusting TimeNest to manage your team's time with integrity and care.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>