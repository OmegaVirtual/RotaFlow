@model Rota.Models.Shift

@{
    ViewData["Title"] = "Create Shift";
    var defaultNote = "If you're interested in picking up this shift, please contact a Manager for approval.";
}

<div class="container mt-5 mb-5">
    <!-- Added mb-5 for spacing from bottom -->
    <div class="row justify-content-center">
        <div class="col-lg-8 animate__animated animate__fadeIn">
            <div class="card shadow-lg border-0">
                <div class="card-header text-white d-flex align-items-center" style="background: linear-gradient(90deg, #1f1c2c, #928dab);">
                    <h4 class="mb-0"><i class="bi bi-calendar-plus me-2"></i> Create New Shift</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Shift Title</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-briefcase"></i></span>
                                <input asp-for="Name" class="form-control" placeholder="e.g., Morning Shift" />
                            </div>
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="StartTime" class="form-label">Start Time</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-clock"></i></span>
                                    <input asp-for="StartTime" class="form-control" type="datetime-local" />
                                </div>
                                <span asp-validation-for="StartTime" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="EndTime" class="form-label">End Time</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-clock-fill"></i></span>
                                    <input asp-for="EndTime" class="form-control" type="datetime-local" />
                                </div>
                                <span asp-validation-for="EndTime" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Location" class="form-label">Location</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-geo-alt"></i></span>
                                <input asp-for="Location" class="form-control" placeholder="e.g., Main Office" />
                            </div>
                            <span asp-validation-for="Location" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="RequiredStaff" class="form-label">Required Staff</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-people-fill"></i></span>
                                <input asp-for="RequiredStaff" class="form-control" type="number" min="1" />
                            </div>
                            <span asp-validation-for="RequiredStaff" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Notes" class="form-label">Additional Notes</label>
                            <textarea asp-for="Notes" class="form-control" rows="3"
                                      placeholder="@defaultNote">@Model.Notes ?? defaultNote</textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Back to Shifts
                            </a>
                            <button type="submit" class="btn btn-gradient">
                                <i class="bi bi-check-circle me-1"></i> Save Shift
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}

<style>
    .btn-gradient {
        background: linear-gradient(90deg, #1f1c2c, #928dab);
        border: none;
        color: white;
    }

        .btn-gradient:hover {
            background: linear-gradient(90deg, #1c1a27, #7f7a95);
            color: white;
        }
</style>
