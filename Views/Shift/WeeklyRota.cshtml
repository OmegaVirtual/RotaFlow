@model IEnumerable<Rota.Models.Shift>
@using Rota.Models
@using Rota.Models.Requests
@inject Rota.Data.ApplicationDbContext Db

@{
    ViewData["Title"] = "Weekly Rota";
    var assignments = ViewBag.Assignments as List<ShiftAssignment> ?? new();
    var profiles = ViewBag.Profiles as Dictionary<string, string> ?? new();
    var autoGeneratedShifts = Model
        .Where(s => s.Notes != null && s.Notes.ToLower().Contains("auto-generated"))
        .OrderBy(s => s.StartTime)
        .ToList();

    bool isManager = User.IsInRole("Manager");

    var groupedShifts = autoGeneratedShifts
        .GroupBy(s => System.Globalization.CultureInfo.InvariantCulture.Calendar.GetWeekOfYear(
            s.StartTime, System.Globalization.CalendarWeekRule.FirstDay, DayOfWeek.Monday))
        .OrderByDescending(g => g.Key)
        .ToList();

    var approvedHolidays = Db.HolidayRequests
        .Where(h => h.Status == HolidayStatus.Approved)
        .ToList();
}

<style>
    .text-gradient {
        background: linear-gradient(to right, #1f1c2c, #928dab);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .table thead {
        background: linear-gradient(to right, #1f1c2c, #928dab);
        color: white;
    }

    .table tbody tr:hover {
        background-color: #f1f3f5;
    }

    .btn-gradient {
        background: linear-gradient(90deg, #1f1c2c, #928dab);
        border: none;
        color: white;
    }

        .btn-gradient:hover {
            background: linear-gradient(90deg, #1c1a2a, #7e7aa6);
            color: white;
        }

    .badge-primary-custom {
        background: linear-gradient(90deg, #1f1c2c, #928dab);
        color: white;
    }

    @@media print {
        .no-print, .btn, .table td:last-child, .table th:last-child {
            display: none !important;
        }
    }
</style>

<div class="container-fluid px-4 mt-4 mb-5 animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-6 fw-bold text-gradient">
            <i class="bi bi-calendar-range me-2"></i> Weekly Rota Overview
        </h1>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-dark btn-sm no-print" onclick="window.print()">
                <i class="bi bi-printer me-1"></i> Print Rota
            </button>
            <form asp-action="DeleteRota" method="post" onsubmit="return confirm('Are you sure you want to delete the entire weekly rota?');">
                <button type="submit" class="btn btn-outline-danger btn-sm no-print">
                    <i class="bi bi-trash me-1"></i> Delete Rota
                </button>
            </form>
        </div>
    </div>

    @if (!autoGeneratedShifts.Any())
    {
        <div class="alert alert-info text-center fs-5 py-4 shadow-sm animate__animated animate__fadeIn">
            <i class="bi bi-info-circle me-2"></i>No weekly rota shifts found.
        </div>
    }
    else
    {
        <div class="row row-cols-1 g-4 animate__animated animate__fadeInUp">
            @foreach (var weekGroup in groupedShifts)
            {
                var weekShifts = weekGroup.OrderBy(s => s.StartTime).ToList();
                var weekStart = weekShifts.First().StartTime.Date.AddDays(-(int)weekShifts.First().StartTime.DayOfWeek + 1);
                var weekEnd = weekStart.AddDays(6);
                var weekLabel = $"{weekStart:dd MMM} – {weekEnd:dd MMM}";

                var weekUnavailable = approvedHolidays
                .Where(h => h.StartDate <= weekEnd && h.EndDate >= weekStart)
                .Select(h => new
                {
                    Name = profiles.ContainsKey(h.UserId) ? profiles[h.UserId] : h.User?.UserName,
                    Range = $"{h.StartDate:dd MMM} – {h.EndDate:dd MMM}"
                })
                .Where(x => !string.IsNullOrEmpty(x.Name))
                .Distinct()
                .ToList();

                <div class="card shadow-sm border-0">
                    <div class="card-header bg-dark text-white fw-semibold small">
                        <i class="bi bi-calendar-week me-1"></i> Week @weekLabel
                    </div>
                    <div class="card-body p-3">
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover shadow-sm bg-white align-middle">
                                <thead class="text-center">
                                    <tr>
                                        <th><i class="bi bi-calendar-event me-1"></i>Date</th>
                                        <th><i class="bi bi-clock me-1"></i>Time</th>
                                        <th><i class="bi bi-geo-alt me-1"></i>Location</th>
                                        <th><i class="bi bi-people-fill me-1"></i>Assigned Staff</th>
                                        @if (isManager)
                                        {
                                            <th class="no-print"><i class="bi bi-pencil-square me-1"></i>Action</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var shift in weekShifts)
                                    {
                                        var assignedUsers = assignments
                                        .Where(a => a.ShiftId == shift.Id && a.User != null)
                                        .Select(a => profiles.ContainsKey(a.UserId) ? profiles[a.UserId] : a.User.UserName)
                                        .ToList();

                                        var day = shift.StartTime.ToString("dddd, dd MMM");
                                        var time = $"{shift.StartTime:HH:mm} – {shift.EndTime:HH:mm}";

                                        <tr>
                                            <td class="fw-semibold">@day</td>
                                            <td>@time</td>
                                            <td>@shift.Location</td>
                                            <td>
                                                @if (assignedUsers.Any())
                                                {
                                                    <ul class="mb-0 ps-3 small">
                                                        @foreach (var user in assignedUsers)
                                                        {
                                                            <li><i class="bi bi-person-circle text-primary me-1"></i>@user</li>
                                                        }
                                                    </ul>
                                                }
                                                else
                                                {
                                                    <span class="text-muted fst-italic">No one assigned</span>
                                                }
                                            </td>
                                            @if (isManager)
                                            {
                                                <td class="text-center no-print">
                                                    <div class="d-flex justify-content-center gap-2">
                                                        <a asp-action="Edit" asp-route-id="@shift.Id" class="btn btn-sm btn-gradient rounded-pill px-3">
                                                            <i class="bi bi-pencil me-1"></i> Edit
                                                        </a>
                                                        <a asp-action="Delete" asp-route-id="@shift.Id" class="btn btn-sm btn-outline-danger rounded-pill px-3"
                                                           onclick="return confirm('Are you sure you want to delete this shift?');">
                                                            <i class="bi bi-trash me-1"></i> Delete
                                                        </a>
                                                    </div>
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (weekUnavailable.Any())
                        {
                            <div class="mt-3 alert alert-warning py-2 small mb-0">
                                <i class="bi bi-person-dash-fill me-1"></i>
                                <strong>Unavailable this week:</strong>
                                @string.Join(", ", weekUnavailable.Select(x => $"{x.Name} ({x.Range})"))
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>
