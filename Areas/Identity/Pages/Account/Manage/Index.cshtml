@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<style>
    .profile-header {
        background: linear-gradient(90deg, #1f1c2c, #928dab);
        padding: 1rem;
        border-top-left-radius: 1rem;
        border-top-right-radius: 1rem;
        color: white;
    }

    .profile-form-container {
        margin-top: 40px;
        margin-bottom: 40px;
        animation: fadeInUp 0.5s ease-in-out;
    }

    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .profile-card {
        border-radius: 1rem;
        overflow: hidden;
    }

    .nav-link.active {
        background-color: #ffc107 !important;
        color: #1f1c2c !important;
    }

    .profile-picture {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border-radius: 50%;
        border: 4px solid #fff;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.3);
        background-color: #eee;
    }

    .picture-wrapper {
        margin-bottom: 2rem;
        display: flex;
        justify-content: center;
        align-items: start;
    }
</style>

<div class="container profile-form-container">
    <div class="row">

        <!-- Profile Picture Column -->
        <div class="col-md-2 picture-wrapper">
            @{
                var profileImage = !string.IsNullOrEmpty(Model.Profile?.ProfileImagePath)
                    ? Model.Profile.ProfileImagePath
                    : "/images/default-user.png";
            }
            <img src="@profileImage" alt="Profile Picture" class="profile-picture" />
        </div>

        <!-- Profile Form -->
        <div class="col-md-7">
            <form id="profile-form" method="post" class="card shadow-lg profile-card border-0">
                <div class="profile-header text-center mb-3">
                    <h3 class="mb-0"><i class="bi bi-person-circle me-2"></i>@ViewData["Title"]</h3>
                </div>

                <div class="px-4 pb-4">
                    <partial name="_StatusMessage" for="StatusMessage" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                    <!-- Email (readonly) -->
                    <div class="form-floating mb-3">
                        <input type="email" class="form-control" value="@Model.Email" readonly />
                        <label>Email</label>
                    </div>

                    <!-- Full Name (readonly) -->
                    <div class="form-floating mb-3">
                        <input asp-for="Input.FullName" class="form-control" placeholder="Full Name" disabled />
                        <label asp-for="Input.FullName" class="form-label"></label>
                    </div>

                    <!-- Date of Birth (editable) -->
                    <div class="form-floating mb-3">
                        <input asp-for="Input.DateOfBirth" type="date" class="form-control" />
                        <label asp-for="Input.DateOfBirth" class="form-label"></label>
                        <span asp-validation-for="Input.DateOfBirth" class="text-danger"></span>
                    </div>

                    <!-- Restaurant Name (readonly) -->
                    <div class="form-floating mb-3">
                        <input asp-for="Input.RestaurantName" class="form-control" placeholder="Restaurant Name" disabled />
                        <label asp-for="Input.RestaurantName" class="form-label">The Halston</label>
                    </div>

                    <!-- Phone Number (editable) -->
                    <div class="form-floating mb-4">
                        <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Phone Number" />
                        <label asp-for="Input.PhoneNumber" class="form-label"></label>
                        <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                    </div>

                    <button id="update-profile-button" type="submit" class="w-100 btn btn-lg text-white"
                            style="background: linear-gradient(90deg, #1f1c2c, #928dab);">
                        <i class="bi bi-check-circle me-1"></i>Save
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
