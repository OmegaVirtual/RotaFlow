@page
@model LogoutModel
@{
    ViewData["Title"] = "Goodbye for Now";
}

<div class="container min-vh-100 d-flex align-items-center justify-content-center">
    <div class="col-md-8 animate__animated animate__fadeInUp">
        <div class="card shadow-lg border-0">
            <div class="card-header text-white text-center" style="background: linear-gradient(90deg, #1f1c2c, #928dab); border-top-left-radius: .5rem; border-top-right-radius: .5rem;">
                <h3 class="mb-0"><i class="bi bi-box-arrow-right me-2"></i>See You Soon!</h3>
            </div>
            <div class="card-body text-center py-5">
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                        <p class="fs-5 mb-4">Are you sure you want to log out? You'll be signed out of all shift features and notifications.</p>
                        <button type="submit" class="btn btn-lg text-white px-4"
                                style="background: linear-gradient(90deg, #1f1c2c, #928dab);">
                            <i class="bi bi-door-open-fill me-2"></i> Yes, Log Me Out
                        </button>
                    </form>
                }
                else
                {
                    <div class="alert alert-success text-center mb-4">
                        <i class="bi bi-check-circle-fill me-2 text-success"></i>
                        You have successfully logged out.
                    </div>

                    <p class="fs-5">Thanks for managing your shifts with us today!</p>
                    <p class="text-muted mb-4">If you need to make changes or view your upcoming schedule, you're welcome back anytime.</p>

                    <a class="btn btn-gradient btn-lg px-4" asp-area="Identity" asp-page="/Account/Login">
                        <i class="bi bi-box-arrow-in-right me-2"></i> Log Back In
                    </a>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .btn-gradient {
        background: linear-gradient(90deg, #1f1c2c, #928dab);
        color: white;
        border: none;
    }

        .btn-gradient:hover {
            background: linear-gradient(90deg, #1c1a2c, #807b9a);
            color: white;
        }
</style>
